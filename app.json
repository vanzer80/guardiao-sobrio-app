{
  "expo": {
    "name": "O Guardião Sóbrio",
    "slug": "guardiao-sobrio-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "guardiaosobrio",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vanzer80.guardiaosobrio",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Usar biometria para proteger o acesso ao app."
      }
    },
    "android": {
      "package": "com.vanzer80.guardiaosobrio",
      "adaptiveIcon": {
        "backgroundColor": "#0e0d0c",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://guardiaosobrio.app"
        }
      ],
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "color": "#c8a84b"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0e0d0c"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
