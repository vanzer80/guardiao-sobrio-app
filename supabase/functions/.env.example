# Edge Functions environment variables
# Set these via Supabase Dashboard → Settings → Edge Functions → Secrets
# (NOT in .env.local — these are server-side secrets)

# Supabase (auto-injected in Edge Functions, no need to set manually)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_ESSENTIAL_MONTHLY=price_XXXXX
STRIPE_PRICE_GUARDIAN_MONTHLY=price_XXXXX
STRIPE_PRICE_ESSENTIAL_ANNUAL=price_XXXXX
STRIPE_PRICE_GUARDIAN_ANNUAL=price_XXXXX

# App deep link scheme (for redirect after checkout)
APP_SCHEME=guardiaosobrio

# -----------------------------------------------------------------------------
# Companion Chat (companion-chat) — backend de LLM (ADR-0002, D2)
# Provedor PRIMÁRIO gratuito + OpenAI como FALLBACK. Um provedor só é usado se
# tiver API key definida. Formato OpenAI-compatible (Groq/OpenRouter/Gemini/OpenAI).
# -----------------------------------------------------------------------------

# Primário gratuito (default = Groq). Troque base_url/model para usar outro.
COMPANION_PRIMARY_BASE_URL=https://api.groq.com/openai/v1
COMPANION_PRIMARY_API_KEY=YOUR_FREE_PROVIDER_KEY_HERE
COMPANION_PRIMARY_MODEL=llama-3.3-70b-versatile

# Fallback OpenAI
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
